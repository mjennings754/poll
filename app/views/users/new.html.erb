<h1>Users#new</h1>
<p>Find me in app/views/users/new.html.erb</p>
<%= form_with model: @user do |form| %>
<%= form.label :username %>
<%= form.text_field :username %>
<%= form.label :password %>
<%= form.password_field :password %>
<%= form.label :confirmation %>
<%= form.password_field :password_confirmation %>
<%= form.submit %>
<% end %>